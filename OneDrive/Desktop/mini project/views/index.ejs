<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
        <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <h3 class="text-2xl font-bold mb-5">Create Account</h3>
        <% if (success && success.length) { %>
            <div class="mb-4 rounded-md bg-green-600 px-4 py-3 text-white"><%= success[0] %></div>
        <% } %>
        <% if (error && error.length) { %>
            <div class="mb-4 rounded-md bg-red-600 px-4 py-3 text-white"><%= error[0] %></div>
        <% } %>
        <form action="/register" method="post">
            <input class="px-3 py-2 outline-none bg-transparent rounded-md text-white placeholder:text-zinc-500 border border-zinc-500 focus:outline-none focus:ring-2 focus:ring-blue-500" type="text" placeholder="name" name="name" required>
            <input class="px-3 py-2 outline-none bg-transparent rounded-md text-white placeholder:text-zinc-500 border border-zinc-500 focus:outline-none focus:ring-2 focus:ring-blue-500" type="text" placeholder="username" name="username" required>
            <input class="px-3 py-2 outline-none bg-transparent rounded-md text-white placeholder:text-zinc-500 border border-zinc-500 focus:outline-none focus:ring-2 focus:ring-blue-500" type="number" placeholder="age" name="age" required>
            <input class="px-3 py-2 outline-none bg-transparent rounded-md text-white placeholder:text-zinc-500 border border-zinc-500 focus:outline-none focus:ring-2 focus:ring-blue-500" type="email" placeholder="email" name="email" required>
            <input class="px-3 py-2 outline-none bg-transparent rounded-md text-white placeholder:text-zinc-500 border border-zinc-500 focus:outline-none focus:ring-2 focus:ring-blue-500" type="password" placeholder="password" name="password" required>
            <input class="px-5 py-2 bg-blue-500 rounded-md hover:bg-blue-600 text-white font-bold rounded gap-3" type="submit" value="Create Account">
        </form>
        <form action="/logout" method="post" class="mt-6">
            <button class="px-5 py-2 bg-red-500 rounded-md hover:bg-red-600 text-white font-bold" type="submit">Logout</button>
        </form>
    </div>
</body>
</html>