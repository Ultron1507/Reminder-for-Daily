<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
        <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <div class="flex justify-end">
            <form action="/logout" method="POST">
                <button type="submit" class="bg-red-600 text-white py-2 px-4 rounded-md">Logout</button>
            </form>
        </div>
        <h3 class="text-2xl font-bold mb-2"><span class="font-light">Hello, <%= user.name %>🐋</span></h3>
        <h5 class="mb-5">you can create a new post.</h5>
        <form action="">
            <textarea placeholder="what's on your mind?" class="w-1/3 p-3 block outline-none resize-none bg-transparent border-2 border-zinc-800 rounded-md" name=""></textarea>
            <input class="w-40 px-3 py-2 block bg-blue-500 rounded-md mt-3  text-sm" type="submit" value="Create New Post">
        </form>
    </div>
</body>
</html>