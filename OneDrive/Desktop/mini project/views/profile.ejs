<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
        <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <div class="flex justify-end">
            <form action="/logout" method="POST">
                <button type="submit" class="bg-red-600 text-white py-2 px-4 rounded-md">Logout</button>
            </form>
        </div>
        <h3 class="text-2xl font-bold mb-2"><span class="font-light">Hello, <%= user.name %>🐋</span></h3>
        <h5 class="mb-5">you can create a new post.</h5>
        <form method="post" action="/post">
            <textarea placeholder="what's on your mind?" class="w-1/3 p-3 block outline-none resize-none bg-transparent border-2 border-zinc-800 rounded-md" name="content"></textarea>
            <input class="w-40 px-3 py-2 block bg-blue-500 rounded-md mt-3  text-sm" type="submit" value="Create New Post">
        </form>
        <div class="posts mt-10">
            <h3 class="text-zinc-400">Recent Posts</h3>
            <div class="postcontainer mt-5 flex gap-5">
                <% user.post.reverse().forEach(post => { %>
                <div class="post w-1/3 p-5 mb-4 rounded-md border-[1px] bg-zinc-800 border-zinc-400 hover:bg-zinc-900">
                    <h4 class="text-blue-600 mb-2">@<%= user.name %></h4>
                    <p class="text-zinc-300 text-sm tracking-tight"><%= post.content %></p>
                    <div class="btns flex mt-5">
                        <a class="text-blue-500" href="">Like</a>
                        <a class="text-green-500 ml-4" href="">Edit</a>
                    </div>
                </div>
            <% }) %>
            </div>
       </div>
    </div>

    
</body>
</html>